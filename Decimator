<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Decimal Math Practice</title>
  <style>
    :root {
      --bg: #f6f8fb;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --accent: #2563eb;
      --accent-dark: #1d4ed8;
      --good: #166534;
      --bad: #b91c1c;
      --border: #dbe3ee;
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
      padding: 24px;
    }

    .container {
      max-width: 900px;
      margin: 0 auto;
    }

    .card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 24px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.06);
    }

    h1, h2, h3 { margin-top: 0; }

    .muted { color: var(--muted); }

    .row {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      align-items: center;
    }

    .problem-box {
      font-size: 2rem;
      font-weight: bold;
      padding: 20px;
      border: 2px dashed var(--border);
      border-radius: 16px;
      text-align: center;
      margin: 20px 0;
      background: #fbfdff;
    }

    input[type="number"] {
      width: 220px;
      max-width: 100%;
      padding: 12px 14px;
      font-size: 1rem;
      border-radius: 12px;
      border: 1px solid var(--border);
    }

    button {
      border: none;
      border-radius: 12px;
      padding: 12px 18px;
      font-size: 1rem;
      cursor: pointer;
      background: var(--accent);
      color: white;
      font-weight: 600;
    }

    button:hover { background: var(--accent-dark); }
    button.secondary { background: #64748b; }

    .feedback {
      min-height: 28px;
      font-weight: bold;
      margin-top: 12px;
    }

    .correct { color: var(--good); }
    .wrong { color: var(--bad); }

    .hidden { display: none; }

    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 12px;
      margin-bottom: 18px;
    }

    .stat {
      background: #f8fbff;
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 14px;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 16px;
      font-size: 0.95rem;
    }

    th, td {
      border: 1px solid var(--border);
      padding: 10px;
      text-align: left;
      vertical-align: top;
    }

    th { background: #eef4ff; }

    @media (max-width: 640px) {
      .problem-box { font-size: 1.5rem; }
      body { padding: 12px; }
      .card { padding: 16px; }
    }
  </style>
</head>
<body>
  <div class="container">
    <div id="startScreen" class="card">
      <h1>Decimal Math Practice</h1>
      <p class="muted">
        Practice multiplying and dividing decimals with 3-digit numbers. You will get 20 problems,
        up to 3 tries per problem, and a review page at the end.
      </p>
      <ul>
        <li>3-digit numbers only</li>
        <li>Decimal multiplication and division</li>
        <li>No repeated problems</li>
        <li>20 total problems</li>
      </ul>
      <button id="startBtn">Start Practice</button>
    </div>

    <div id="quizScreen" class="card hidden">
      <div class="stats">
        <div class="stat"><strong>Problem:</strong> <span id="problemCount">1</span> / 20</div>
        <div class="stat"><strong>Attempt:</strong> <span id="attemptCount">1</span> / 3</div>
        <div class="stat"><strong>Correct So Far:</strong> <span id="correctCount">0</span></div>
      </div>

      <div id="problemText" class="problem-box"></div>

      <div class="row">
        <input id="answerInput" type="number" step="0.01" placeholder="Enter your answer" />
        <button id="submitBtn">Submit</button>
      </div>

      <div id="feedback" class="feedback"></div>
      <p class="muted">Tip: Enter answers to 2 decimal places when needed.</p>
    </div>

    <div id="reviewScreen" class="card hidden">
      <h2>Practice Review</h2>
      <div class="stats">
        <div class="stat"><strong>Total Problems:</strong> 20</div>
        <div class="stat"><strong>Correct:</strong> <span id="finalCorrect">0</span></div>
        <div class="stat"><strong>Score:</strong> <span id="finalScore">0%</span></div>
      </div>

      <div class="row">
        <button id="restartBtn">Practice Again</button>
      </div>

      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Problem</th>
            <th>Your Last Answer</th>
            <th>Correct Answer</th>
            <th>Attempts</th>
            <th>Result</th>
          </tr>
        </thead>
        <tbody id="reviewBody"></tbody>
      </table>
    </div>
  </div>

  <script>
    const TOTAL_PROBLEMS = 20;
    const MAX_ATTEMPTS = 3;

    let problems = [];
    let results = [];
    let currentProblemIndex = 0;
    let currentAttempt = 1;
    let correctAnswers = 0;

    const startScreen = document.getElementById('startScreen');
    const quizScreen = document.getElementById('quizScreen');
    const reviewScreen = document.getElementById('reviewScreen');

    const startBtn = document.getElementById('startBtn');
    const submitBtn = document.getElementById('submitBtn');
    const restartBtn = document.getElementById('restartBtn');

    const problemCount = document.getElementById('problemCount');
    const attemptCount = document.getElementById('attemptCount');
    const correctCount = document.getElementById('correctCount');
    const problemText = document.getElementById('problemText');
    const answerInput = document.getElementById('answerInput');
    const feedback = document.getElementById('feedback');

    const finalCorrect = document.getElementById('finalCorrect');
    const finalScore = document.getElementById('finalScore');
    const reviewBody = document.getElementById('reviewBody');

    startBtn.addEventListener('click', startPractice);
    submitBtn.addEventListener('click', submitAnswer);
    restartBtn.addEventListener('click', startPractice);
    answerInput.addEventListener('keydown', function (event) {
      if (event.key === 'Enter') submitAnswer();
    });

    function startPractice() {
      problems = generateUniqueProblems(TOTAL_PROBLEMS);
      results = [];
      currentProblemIndex = 0;
      currentAttempt = 1;
      correctAnswers = 0;

      startScreen.classList.add('hidden');
      reviewScreen.classList.add('hidden');
      quizScreen.classList.remove('hidden');

      showProblem();
    }

    function showProblem() {
      const currentProblem = problems[currentProblemIndex];
      problemCount.textContent = currentProblemIndex + 1;
      attemptCount.textContent = currentAttempt;
      correctCount.textContent = correctAnswers;
      problemText.textContent = currentProblem.question;
      answerInput.value = '';
      feedback.textContent = '';
      feedback.className = 'feedback';
      answerInput.focus();
    }

    function submitAnswer() {
      const value = answerInput.value.trim();
      if (value === '') {
        feedback.textContent = 'Please enter an answer.';
        feedback.className = 'feedback wrong';
        return;
      }

      const studentAnswer = Number(value);
      const currentProblem = problems[currentProblemIndex];
      const isCorrect = nearlyEqual(studentAnswer, currentProblem.answer);

      if (isCorrect) {
        feedback.textContent = 'Correct! Great job.';
        feedback.className = 'feedback correct';
        correctAnswers++;

        results.push({
          number: currentProblemIndex + 1,
          problem: currentProblem.question,
          studentAnswer: studentAnswer.toFixed(2),
          correctAnswer: currentProblem.answer.toFixed(2),
          attempts: currentAttempt,
          result: 'Correct'
        });

        moveToNextProblem();
      } else {
        if (currentAttempt < MAX_ATTEMPTS) {
          feedback.textContent = 'Wrong. Try again.';
          feedback.className = 'feedback wrong';
          currentAttempt++;
          attemptCount.textContent = currentAttempt;
          answerInput.select();
        } else {
          feedback.textContent = `Wrong. The correct answer was ${currentProblem.answer.toFixed(2)}.`;
          feedback.className = 'feedback wrong';

          results.push({
            number: currentProblemIndex + 1,
            problem: currentProblem.question,
            studentAnswer: studentAnswer.toFixed(2),
            correctAnswer: currentProblem.answer.toFixed(2),
            attempts: currentAttempt,
            result: 'Wrong'
          });

          setTimeout(moveToNextProblem, 1200);
        }
      }
    }

    function moveToNextProblem() {
      currentProblemIndex++;
      currentAttempt = 1;

      if (currentProblemIndex >= TOTAL_PROBLEMS) {
        showReview();
      } else {
        showProblem();
      }
    }

    function showReview() {
      quizScreen.classList.add('hidden');
      reviewScreen.classList.remove('hidden');

      finalCorrect.textContent = correctAnswers;
      finalScore.textContent = Math.round((correctAnswers / TOTAL_PROBLEMS) * 100) + '%';

      reviewBody.innerHTML = '';
      for (const item of results) {
        const row = document.createElement('tr');
        row.innerHTML = `
          <td>${item.number}</td>
          <td>${item.problem}</td>
          <td>${item.studentAnswer}</td>
          <td>${item.correctAnswer}</td>
          <td>${item.attempts}</td>
          <td>${item.result}</td>
        `;
        reviewBody.appendChild(row);
      }
    }

    function generateUniqueProblems(count) {
      const set = new Set();
      const list = [];

      while (list.length < count) {
        const problem = createRandomProblem();
        if (!set.has(problem.key)) {
          set.add(problem.key);
          list.push(problem);
        }
      }

      return list;
    }

    function createRandomProblem() {
      const operationChoice = Math.floor(Math.random() * 2);
      let num1, num2, answer, question, key;

      if (operationChoice === 0) {
        num1 = round2(randomDecimal3Digits());
        num2 = round2(randomDecimal3Digits());
        answer = round2(num1 * num2);
        question = `${num1.toFixed(2)} × ${num2.toFixed(2)}`;
        key = `M:${num1}:${num2}`;
      } else {
        num2 = round2(randomDecimal3Digits());
        answer = round2(randomDecimalTwoDigits());
        num1 = round2(num2 * answer);
        question = `${num1.toFixed(2)} ÷ ${num2.toFixed(2)}`;
        key = `D:${num1}:${num2}`;
      }

      return { question, answer, key };
    }

    function randomDecimal3Digits() {
      return Math.floor(Math.random() * 900 + 100) + Math.random();
    }

    function randomDecimalTwoDigits() {
      return Math.floor(Math.random() * 90 + 10) + Math.random();
    }

    function round2(value) {
      return Math.round(value * 100) / 100;
    }

    function nearlyEqual(a, b) {
      return Math.abs(a - b) < 0.01;
    }
  </script>
</body>
</html>
